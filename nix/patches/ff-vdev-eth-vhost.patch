diff --color -ruN va/lib/ff_config.c vb/lib/ff_config.c
--- a/lib/ff_config.c	2026-06-13 18:25:44.131114602 +0000
+++ b/lib/ff_config.c	2026-06-13 18:26:00.125564314 +0000
@@ -1114,7 +1114,34 @@
     }
 
     if (cfg->dpdk.nb_vdev) {
+        int nb_virtio_user = 0;
         for (i=0; i<cfg->dpdk.nb_vdev; i++) {
+            /*
+             * iface => vhost-user backend (eth_vhost): creates the unix
+             * socket and serves the rings; the peer is a virtio_user
+             * frontend, e.g. another F-Stack instance with path= set.
+             */
+            if (cfg->dpdk.vdev_cfgs[i].iface) {
+                sprintf(temp, "--vdev=eth_vhost%d,iface=%s",
+                    cfg->dpdk.vdev_cfgs[i].vdev_id,
+                    cfg->dpdk.vdev_cfgs[i].iface);
+                if (cfg->dpdk.vdev_cfgs[i].nb_queues) {
+                    sprintf(temp2, ",queues=%u",
+                        cfg->dpdk.vdev_cfgs[i].nb_queues);
+                    strcat(temp, temp2);
+                }
+                /*
+                 * tso=1 makes the backend offer VIRTIO_NET_F_HOST_TSO4/6 so
+                 * the virtio_user frontend can push GSO super-segments
+                 * (~64KB) through the ring instead of MSS-sized packets;
+                 * tso=0 (default) disables them. Tied to [dpdk] tso.
+                 */
+                sprintf(temp2, ",tso=%d", cfg->dpdk.tso);
+                strcat(temp, temp2);
+                dpdk_argv[n++] = strdup(temp);
+                continue;
+            }
+            nb_virtio_user++;
             sprintf(temp, "--vdev=virtio_user%d,path=%s",
                 cfg->dpdk.vdev_cfgs[i].vdev_id,
                 cfg->dpdk.vdev_cfgs[i].path);
@@ -1142,6 +1169,14 @@
         }
         sprintf(temp, "--no-pci");
         dpdk_argv[n++] = strdup(temp);
+        /*
+         * virtio_user hands its memory to the vhost backend as a region
+         * table with a small fd limit; one fd per memseg list (instead of
+         * one per page) keeps the table within bounds.
+         */
+        if (nb_virtio_user) {
+            dpdk_argv[n++] = strdup("--single-file-segments");
+        }
         if (!cfg->dpdk.file_prefix) {
             sprintf(temp, "--file-prefix=container");
