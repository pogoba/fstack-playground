+
+/*
+ * Native-app feature getters (config-driven, read after ff_init()): let the
+ * application opt into zero-copy recv/send via the f-stack config file
+ * instead of its own env/flags.  See [dpdk] zc_recv / zc_send.
+ */
+int
+ff_zc_recv_enabled(void)
+{
+    return ff_global_cfg.dpdk.zc_recv;
+}
+
+int
+ff_zc_send_enabled(void)
+{
+    return ff_global_cfg.dpdk.zc_send;
+}
