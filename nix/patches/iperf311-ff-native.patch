 /**************************************************************************/
+#ifdef FF_NATIVE
+/* Initialize the embedded F-Stack instance before anything touches the
+ * network. Configuration via environment: FF_CONF (default ./config.ini),
+ * FF_PROC_TYPE (primary), FF_PROC_ID (0). */
+static void
+ff_native_init(void)
+{
+    static char ptype[64], pid[64];
+    const char *conf = getenv("FF_CONF");
+    if (conf == NULL)
+        conf = "./config.ini";
+    snprintf(ptype, sizeof(ptype), "--proc-type=%s",
+        getenv("FF_PROC_TYPE") ? getenv("FF_PROC_TYPE") : "primary");
+    snprintf(pid, sizeof(pid), "--proc-id=%s",
+        getenv("FF_PROC_ID") ? getenv("FF_PROC_ID") : "0");
+    char *ff_argv[] = { "iperf3", "--conf", (char *) conf, ptype, pid };
+    if (ff_init(5, ff_argv) < 0) {
+        fprintf(stderr, "iperf3: ff_init failed\n");
+        exit(1);
+    }
+    /* ff_init/rte_eal_init parse their own argv with getopt and leave the
+     * global parser state behind; reset it for iperf's option parsing. */
+    optind = 0;
+}
+#endif
+
+
 int
 main(int argc, char **argv)
 {
+#ifdef FF_NATIVE
+    ff_native_init();
+#endif
     struct iperf_test *test;
 
     // XXX: Setting the process affinity requires root on most systems.
