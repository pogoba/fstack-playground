+/*
+ * Zero-copy receive: hand the application the received mbuf chain instead
+ * of uiomove()ing the payload into a user buffer.  soreceive() with a
+ * non-NULL mp0 transfers mbuf ownership to the caller, who must release the
+ * chain with ff_mbuf_free() when done.  Returns the number of bytes in the
+ * returned chain (0 on EOF), or -1 with errno set (EWOULDBLOCK when no data
+ * is ready on a non-blocking socket).
+ */
+ssize_t
+ff_recv_mbuf(int s, void **mb, size_t len, int flags)
+{
+    struct thread *td = curthread;
+    struct file *fp;
+    struct socket *so;
+    struct uio auio;
+    struct mbuf *m = NULL;
+    int rcvflags = flags;
+    int rc;
+
+    if (mb == NULL || len > INT_MAX) {
+        rc = EINVAL;
+        goto kern_fail;
+    }
+
+    if ((rc = getsock(td, s, NULL, &fp)) != 0)
+        goto kern_fail;
+    so = (struct socket *)fp->f_data;
+
+    bzero(&auio, sizeof(auio));
+    auio.uio_resid = len;
+    auio.uio_segflg = UIO_SYSSPACE;
+    auio.uio_rw = UIO_READ;
+    auio.uio_td = td;
+
+    rc = soreceive(so, NULL, &auio, &m, NULL, &rcvflags);
+    fdrop(fp, td);
+
+    if (rc != 0) {
+        if (auio.uio_resid != (ssize_t)len &&
+            (rc == ERESTART || rc == EINTR || rc == EWOULDBLOCK))
+            rc = 0;
+        else
+            goto kern_fail;
+    }
+
+    *mb = (void *)m;
+    return (ssize_t)(len - auio.uio_resid);
+kern_fail:
+    if (mb != NULL)
+        *mb = NULL;
+    ff_os_errno(rc);
+    return (-1);
+}
