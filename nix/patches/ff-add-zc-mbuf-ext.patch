+/* Zero-copy send from an application-owned buffer: wrap it in an external
+ * mbuf (no data copy) for ff_zc_send.  The buffer must stay valid and
+ * unmodified until the stack has ACK'd the data; a constant/reused send
+ * buffer (e.g. iperf's) satisfies this.  The ext free callback is a no-op
+ * because the application, not the stack, owns the storage. */
+static void
+ff_zc_ext_noop_free(struct mbuf *m)
+{
+    (void)m;
+}
+
+int
+ff_zc_mbuf_ext(struct ff_zc_mbuf *m, void *buf, int len)
+{
+    struct mbuf *mb;
+
+    if (m == NULL || buf == NULL || len <= 0) {
+        return -1;
+    }
+
+    mb = m_gethdr(M_WAITOK, MT_DATA);
+    if (mb == NULL) {
+        return -1;
+    }
+
+    m_extadd(mb, (char *)buf, len, ff_zc_ext_noop_free, NULL, NULL, 0,
+        EXT_DISPOSABLE);
+    mb->m_len = len;
+    mb->m_pkthdr.len = len;
+    mb->m_next = NULL;
+    mb->m_nextpkt = NULL;
+
+    m->bsd_mbuf = m->bsd_mbuf_off = mb;
+    m->off = len;
+    m->len = len;
+
+    return 0;
+}
