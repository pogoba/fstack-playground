diff --color -ruN da/lib/ff_dpdk_if.c db/lib/ff_dpdk_if.c
--- a/lib/ff_dpdk_if.c	2026-06-13 18:56:10.491810782 +0000
+++ b/lib/ff_dpdk_if.c	2026-06-13 18:56:10.513811406 +0000
@@ -735,13 +735,38 @@
                 }
                 #endif
 
-                /* Set Rx checksum checking */
-                if ((dev_info.rx_offload_capa & RTE_ETH_RX_OFFLOAD_IPV4_CKSUM) &&
-                    (dev_info.rx_offload_capa & RTE_ETH_RX_OFFLOAD_UDP_CKSUM) &&
-                    (dev_info.rx_offload_capa & RTE_ETH_RX_OFFLOAD_TCP_CKSUM)) {
-                    ff_log(FF_LOG_INFO, FF_LOGTYPE_FSTACK_LIB, "RX checksum offload supported\n");
-                    port_conf.rxmode.offloads |= RTE_ETH_RX_OFFLOAD_CHECKSUM;
-                    pconf->hw_features.rx_csum = 1;
+                /* Set Rx checksum checking.
+                 *
+                 * Upstream demanded IPv4 + UDP + TCP csum offload all be
+                 * advertised before enabling rx_csum.  Request whatever
+                 * subset the device offers.  Devices that validate all three
+                 * (real NICs) are trusted unconditionally.  An L4-csum-only
+                 * device -- the vhost-user PMD advertises TCP+UDP but NOT
+                 * IPv4 -- does not actually validate, so trusting it (and
+                 * thus stopping eth_vhost's SW completion + FreeBSD's
+                 * re-verify) is gated on the config flag [dpdk] rx_csum_trust:
+                 * with it on, no full checksum is computed end to end on the
+                 * shared-memory link; with it off, the old wasteful
+                 * double-checksum path is kept. */
+                {
+                    uint64_t rxc = dev_info.rx_offload_capa &
+                        (RTE_ETH_RX_OFFLOAD_IPV4_CKSUM |
+                         RTE_ETH_RX_OFFLOAD_UDP_CKSUM |
+                         RTE_ETH_RX_OFFLOAD_TCP_CKSUM);
+                    int have_all3 =
+                        (rxc & RTE_ETH_RX_OFFLOAD_IPV4_CKSUM) &&
+                        (rxc & RTE_ETH_RX_OFFLOAD_UDP_CKSUM) &&
+                        (rxc & RTE_ETH_RX_OFFLOAD_TCP_CKSUM);
+                    int l4_only =
+                        (rxc & (RTE_ETH_RX_OFFLOAD_UDP_CKSUM |
+                                RTE_ETH_RX_OFFLOAD_TCP_CKSUM)) &&
+                        !(rxc & RTE_ETH_RX_OFFLOAD_IPV4_CKSUM);
+                    if (have_all3 ||
+                        (l4_only && ff_global_cfg.dpdk.rx_csum_trust)) {
+                        ff_log(FF_LOG_INFO, FF_LOGTYPE_FSTACK_LIB, "RX checksum offload supported\n");
+                        port_conf.rxmode.offloads |= rxc;
+                        pconf->hw_features.rx_csum = 1;
+                    }
                 }
 
                 if (dev_info.rx_offload_capa & RTE_ETH_RX_OFFLOAD_TIMESTAMP) {
@@ -1495,7 +1520,14 @@
 {
     uint8_t rx_csum = ctx->hw_features.rx_csum;
     if (rx_csum) {
-        if (pkt->ol_flags & (RTE_MBUF_F_RX_IP_CKSUM_BAD | RTE_MBUF_F_RX_L4_CKSUM_BAD)) {
+        /*
+         * _NONE == _BAD | _GOOD, so a plain "& _BAD" test also matches a
+         * NONE result and would wrongly drop the packet.  The vhost-user
+         * PMD reports L4 csum NONE (it does not validate on a shared-memory
+         * link); only drop when the field is *exactly* BAD.
+         */
+        if ((pkt->ol_flags & RTE_MBUF_F_RX_IP_CKSUM_MASK) == RTE_MBUF_F_RX_IP_CKSUM_BAD ||
+            (pkt->ol_flags & RTE_MBUF_F_RX_L4_CKSUM_MASK) == RTE_MBUF_F_RX_L4_CKSUM_BAD) {
             rte_pktmbuf_free(pkt);
             return;
         }
