+/*
+ * Run a single iteration of the stack's event loop: expire timers, drain
+ * pending TX, poll RX queues and process packets, service the msg ring and
+ * (with FF_LOOPBACK_SUPPORT) software interrupts.
+ *
+ * This lets a "pump"-style native application keep its own sequential
+ * control flow and drive the stack explicitly wherever it would otherwise
+ * block, instead of inverting itself into an ff_run() callback. Call only
+ * from the thread that ran ff_init() (the DPDK main lcore). Returns 0 when
+ * the iteration was idle, 1 when any work was done.
+ */
+int
+ff_pump(void)
+{
+    struct rte_mbuf *pkts_burst[MAX_PKT_BURST];
+    uint64_t cur_tsc;
+    int i, j, nb_rx, idle = 1;
+    uint16_t port_id, queue_id;
+    struct ff_dpdk_if_context *ctx;
+    struct lcore_conf *qconf = &lcore_conf;
+
+    cur_tsc = rte_rdtsc();
+    if (unlikely(freebsd_clock.expire < cur_tsc)) {
+        rte_timer_manage();
+    }
+
+    /* Pump mode drains buffered TX every call (no pkt_tx_delay batching). */
+    for (i = 0; i < qconf->nb_tx_port; i++) {
+        port_id = qconf->tx_port_id[i];
+        if (qconf->tx_mbufs[port_id].len == 0)
+            continue;
+        idle = 0;
+        send_burst(qconf, qconf->tx_mbufs[port_id].len, port_id);
+        qconf->tx_mbufs[port_id].len = 0;
+    }
+
+    for (i = 0; i < qconf->nb_rx_queue; ++i) {
+        port_id = qconf->rx_queue_list[i].port_id;
+        queue_id = qconf->rx_queue_list[i].queue_id;
+        ctx = veth_ctx[port_id];
+
+        idle &= !process_dispatch_ring(port_id, queue_id, pkts_burst, ctx);
+
+        nb_rx = rte_eth_rx_burst(port_id, queue_id, pkts_burst,
+            MAX_PKT_BURST);
+        if (nb_rx == 0)
+            continue;
+
+        idle = 0;
+
+        for (j = 0; j < PREFETCH_OFFSET && j < nb_rx; j++) {
+            rte_prefetch0(rte_pktmbuf_mtod(pkts_burst[j], void *));
+        }
+
+        for (j = 0; j < (nb_rx - PREFETCH_OFFSET); j++) {
+            rte_prefetch0(rte_pktmbuf_mtod(pkts_burst[
+                    j + PREFETCH_OFFSET], void *));
+            process_packets(port_id, queue_id, &pkts_burst[j], 1, ctx, 0);
+        }
+
+        for (; j < nb_rx; j++) {
+            process_packets(port_id, queue_id, &pkts_burst[j], 1, ctx, 0);
+        }
+    }
+
+    process_msg_ring(qconf->proc_id, pkts_burst);
+#ifdef FF_LOOPBACK_SUPPORT
+    ff_swi_net_excute();
+#endif
+
+    return !idle;
+}
