--- a/lib/ff_kern_timeout.c
+++ b/lib/ff_kern_timeout.c
@@ -187,6 +187,7 @@ struct callout_cpu cc_cpu;
 static int timeout_cpu;
 
 static void callout_cpu_init(struct callout_cpu *cc, int cpu);
