diff --color -ruN zrecv/src/ff_native.h.orig zsend/src/ff_native.h.orig
--- a/src/ff_native.h.orig	1970-01-01 00:00:00.000000000 +0000
+++ b/src/ff_native.h.orig	2026-06-13 18:57:11.732529570 +0000
@@ -0,0 +1,320 @@
+/*
+ * ff_native.h - native F-Stack backend for iperf3.
+ *
+ * Maps the BSD socket calls of this translation unit onto F-Stack's ff_*
+ * API for F-Stack file descriptors (fd >= FF_FD_BASE, i.e. fd_reserve in
+ * the f-stack config), and keeps libc behavior for everything else
+ * (stdio, files, getaddrinfo, ...).
+ *
+ * Blocking semantics: F-Stack sockets cannot block (the stack runs in the
+ * same thread). Every place iperf waits goes through select(), which is
+ * mapped here to a loop of zero-timeout ff_select() + ff_pump() — ff_pump
+ * runs one iteration of the stack's event loop (RX, TX drain, timers), so
+ * the stack makes progress exactly while the application waits.
+ *
+ * Include this header LAST, after all system and iperf headers, in every
+ * .c file that performs socket I/O. The wrapper functions are defined
+ * before the macros so they can call the real libc symbols.
+ */
+
+#ifndef IPERF_FF_NATIVE_H
+#define IPERF_FF_NATIVE_H
+#ifdef FF_NATIVE
+
+#include <sys/types.h>
+#include <sys/socket.h>
+#include <sys/select.h>
+#include <sys/ioctl.h>
+#include <unistd.h>
+#include <fcntl.h>
+#include <errno.h>
+#include <stdarg.h>
+#include <string.h>
+#include <time.h>
+
+#include <ff_api.h>
+
+/* ff_mbuf_free is exported (ff_api.symlist) but not declared in ff_api.h. */
+void ff_mbuf_free(void *mb);
+
+/* Config-driven feature getters (f-stack lib): read [dpdk] zc_recv/zc_send
+ * from the loaded config after ff_init(), so the rig is controlled entirely
+ * from the config file rather than env vars. */
+int ff_zc_recv_enabled(void);
+int ff_zc_send_enabled(void);
+
+/* Defined in iperf_tcp.c (part of libiperf, where it is used); set from
+ * FF_ZC_RECV in ff_native_init(). Nonzero => TCP server drains streams via
+ * ff_recv_mbuf (zero-copy) instead of copying reads. */
+extern int ffn_zc_recv;
+
+#ifndef FF_FD_BASE
+#define FF_FD_BASE 128 /* must equal fd_reserve in the f-stack config */
+#endif
+
+static inline int
+ffn_is(int fd)
+{
+    return fd >= FF_FD_BASE;
+}
+
+static inline int
+ffn_socket(int domain, int type, int protocol)
+{
+    if ((domain == AF_INET || domain == AF_INET6) &&
+        (type == SOCK_STREAM || type == SOCK_DGRAM)) {
+        int fd = ff_socket(domain, type, protocol);
+        if (fd >= 0) {
+            /* F-Stack sockets must never block: the stack runs in this
+             * thread and only makes progress while we pump it. */
+            int on = 1;
+            ff_ioctl(fd, FIONBIO, &on);
+        }
+        return fd;
+    }
+    return socket(domain, type, protocol);
+}
+
+static inline int
+ffn_bind(int fd, const struct sockaddr *addr, socklen_t len)
+{
+    if (ffn_is(fd))
+        return ff_bind(fd, (const struct linux_sockaddr *)(const void *)addr, len);
+    return bind(fd, addr, len);
+}
+
+static inline int
+ffn_listen(int fd, int backlog)
+{
+    if (ffn_is(fd))
+        return ff_listen(fd, backlog);
+    return listen(fd, backlog);
+}
+
+static inline int
+ffn_accept(int fd, struct sockaddr *addr, socklen_t *len)
+{
+    if (ffn_is(fd)) {
+        int nfd = ff_accept(fd, (struct linux_sockaddr *)(void *)addr, len);
+        if (nfd >= 0) {
+            int on = 1;
+            ff_ioctl(nfd, FIONBIO, &on);
+        }
+        return nfd;
+    }
+    return accept(fd, addr, len);
+}
+
+static inline int
+ffn_connect(int fd, const struct sockaddr *addr, socklen_t len)
+{
+    if (ffn_is(fd))
+        return ff_connect(fd, (const struct linux_sockaddr *)(const void *)addr, len);
+    return connect(fd, addr, len);
+}
+
+static inline int
+ffn_close(int fd)
+{
+    if (ffn_is(fd))
+        return ff_close(fd);
+    return close(fd);
+}
+
+static inline ssize_t
+ffn_read(int fd, void *buf, size_t n)
+{
+    if (ffn_is(fd))
+        return ff_read(fd, buf, n);
+    return read(fd, buf, n);
+}
+
+static inline ssize_t
+ffn_write(int fd, const void *buf, size_t n)
+{
+    if (ffn_is(fd))
+        return ff_write(fd, buf, n);
+    return write(fd, buf, n);
+}
+
+static inline ssize_t
+ffn_recv(int fd, void *buf, size_t n, int flags)
+{
+    if (ffn_is(fd))
+        return ff_recv(fd, buf, n, flags);
+    return recv(fd, buf, n, flags);
+}
+
+static inline ssize_t
+ffn_send(int fd, const void *buf, size_t n, int flags)
+{
+    if (ffn_is(fd))
+        return ff_send(fd, buf, n, flags);
+    return send(fd, buf, n, flags);
+}
+
+static inline ssize_t
+ffn_sendto(int fd, const void *buf, size_t n, int flags,
+    const struct sockaddr *addr, socklen_t len)
+{
+    if (ffn_is(fd))
+        return ff_sendto(fd, buf, n, flags,
+            (const struct linux_sockaddr *)(const void *)addr, len);
+    return sendto(fd, buf, n, flags, addr, len);
+}
+
+static inline ssize_t
+ffn_recvfrom(int fd, void *buf, size_t n, int flags,
+    struct sockaddr *addr, socklen_t *len)
+{
+    if (ffn_is(fd))
+        return ff_recvfrom(fd, buf, n, flags,
+            (struct linux_sockaddr *)(void *)addr, len);
+    return recvfrom(fd, buf, n, flags, addr, len);
+}
+
+static inline int
+ffn_setsockopt(int fd, int level, int optname, const void *optval,
+    socklen_t optlen)
+{
+    if (ffn_is(fd))
+        /* ff_setsockopt translates Linux constants to FreeBSD ones */
+        return ff_setsockopt(fd, level, optname, optval, optlen);
+    return setsockopt(fd, level, optname, optval, optlen);
+}
+
+static inline int
+ffn_getsockopt(int fd, int level, int optname, void *optval,
+    socklen_t *optlen)
+{
+    if (ffn_is(fd))
+        return ff_getsockopt(fd, level, optname, optval, optlen);
+    return getsockopt(fd, level, optname, optval, optlen);
+}
+
+static inline int
+ffn_getsockname(int fd, struct sockaddr *addr, socklen_t *len)
+{
+    if (ffn_is(fd))
+        return ff_getsockname(fd, (struct linux_sockaddr *)(void *)addr, len);
+    return getsockname(fd, addr, len);
+}
+
+static inline int
+ffn_getpeername(int fd, struct sockaddr *addr, socklen_t *len)
+{
+    if (ffn_is(fd))
+        return ff_getpeername(fd, (struct linux_sockaddr *)(void *)addr, len);
+    return getpeername(fd, addr, len);
+}
+
+static inline int
+ffn_fcntl(int fd, int cmd, ...)
+{
+    va_list ap;
+    long arg;
+
+    va_start(ap, cmd);
+    arg = va_arg(ap, long);
+    va_end(ap);
+
+    if (ffn_is(fd)) {
+        /* F-Stack sockets are inherently nonblocking; humor the caller. */
+        if (cmd == F_GETFL)
+            return O_RDWR | O_NONBLOCK;
+        if (cmd == F_SETFL)
+            return 0;
+        return ff_fcntl(fd, cmd, arg);
+    }
+    return fcntl(fd, cmd, arg);
+}
+
+static inline int
+ffn_shutdown(int fd, int how)
+{
+    if (ffn_is(fd))
+        return ff_shutdown(fd, how);
+    return shutdown(fd, how);
+}
+
+/*
+ * select() over F-Stack fds: poll with zero timeout and pump the stack
+ * between polls; honor the caller's timeout with CLOCK_MONOTONIC. Mixed
+ * kernel/F-Stack fd sets are not supported (iperf only selects sockets).
+ */
+static inline int
+ffn_select(int nfds, fd_set *rs, fd_set *ws, fd_set *es, struct timeval *tv)
+{
+    struct timespec start, now;
+    fd_set rr, ww, ee;
+    struct timeval zero;
+    long timeout_us = -1;
+    int n;
+
+    if (nfds <= FF_FD_BASE)
+        return select(nfds, rs, ws, es, tv);
+
+    if (tv != NULL)
+        timeout_us = tv->tv_sec * 1000000L + tv->tv_usec;
+    clock_gettime(CLOCK_MONOTONIC, &start);
+
+    /* Always pump at least once so pending TX drains and RX progresses
+     * even when the poll below succeeds immediately. */
+    ff_pump();
+
+    for (;;) {
+        zero.tv_sec = 0;
+        zero.tv_usec = 0;
+        if (rs) rr = *rs;
+        if (ws) ww = *ws;
+        if (es) ee = *es;
+        n = ff_select(nfds, rs ? &rr : NULL, ws ? &ww : NULL,
+                es ? &ee : NULL, &zero);
+        if (n != 0) {
+            if (n > 0) {
+                if (rs) *rs = rr;
+                if (ws) *ws = ww;
+                if (es) *es = ee;
+            }
+            return n;
+        }
+
+        ff_pump();
+
+        if (timeout_us >= 0) {
+            long elapsed;
+            clock_gettime(CLOCK_MONOTONIC, &now);
+            elapsed = (now.tv_sec - start.tv_sec) * 1000000L +
+                (now.tv_nsec - start.tv_nsec) / 1000;
+            if (elapsed >= timeout_us) {
+                if (rs) FD_ZERO(rs);
+                if (ws) FD_ZERO(ws);
+                if (es) FD_ZERO(es);
+                return 0;
+            }
+        }
+    }
+}
+
+#define socket(a, b, c)            ffn_socket(a, b, c)
+#define bind(a, b, c)              ffn_bind(a, b, c)
+#define listen(a, b)               ffn_listen(a, b)
+#define accept(a, b, c)            ffn_accept(a, b, c)
+#define connect(a, b, c)           ffn_connect(a, b, c)
+#define close(a)                   ffn_close(a)
+#define read(a, b, c)              ffn_read(a, b, c)
+#define write(a, b, c)             ffn_write(a, b, c)
+#define recv(a, b, c, d)           ffn_recv(a, b, c, d)
+#define send(a, b, c, d)           ffn_send(a, b, c, d)
+#define sendto(a, b, c, d, e, f)   ffn_sendto(a, b, c, d, e, f)
+#define recvfrom(a, b, c, d, e, f) ffn_recvfrom(a, b, c, d, e, f)
+#define setsockopt(a, b, c, d, e)  ffn_setsockopt(a, b, c, d, e)
+#define getsockopt(a, b, c, d, e)  ffn_getsockopt(a, b, c, d, e)
+#define getsockname(a, b, c)       ffn_getsockname(a, b, c)
+#define getpeername(a, b, c)       ffn_getpeername(a, b, c)
+#define fcntl                      ffn_fcntl
+#define shutdown(a, b)             ffn_shutdown(a, b)
+#define select(a, b, c, d, e)      ffn_select(a, b, c, d, e)
+
+#endif /* FF_NATIVE */
+#endif /* IPERF_FF_NATIVE_H */
